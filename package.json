{
  "name": "fc-git",
  "version": "1.0.0",
  "description": "Advanced Git with Git Flow and SonarQube project as Full Cycle's course practice",
  "keywords": [
    "git",
    "git-flow",
    "sonar-qube"
  ],
  "homepage": "https://github.com/itpzzi/fc-git#readme",
  "bugs": {
    "url": "https://github.com/itpzzi/fc-git/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itpzzi/fc-git.git"
  },
  "license": "ISC",
  "author": "Ítalo Polazzi",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.29.0",
    "husky": "^9.1.7",
    "jest": "^30.0.3",
    "lint-staged": "^16.1.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dayjs": "^1.11.13"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix"
  }
}
